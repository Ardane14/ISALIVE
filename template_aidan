                    client.send_message("/quiz_truth", 1)
                else:
                    print("[OSC] Envoi de 0 à TouchDesigner (Mensonge)")
                    client.send_message("/quiz_truth", 0)

            print(f"[TTS] Texte final lu par la voix : {cleaned_response}")
            await speak(cleaned_response)
            
            print("\n--- Cycle terminé, retour en attente (ESPACE pour parler)... ---")

        except KeyboardInterrupt:
            print("Arrêt demandé par l'utilisateur.")
            break
        except Exception as e:
            print(f"[ERROR] {e}")
            await asyncio.sleep(1)

def check_quiz_question(user_text):
    text = user_text.lower()
    stop_words = {
        "le","la","les","un","une","des",
        "de","du","d","est","et","a","à",
        "quel","quelle","quels","quelles",
        "que","qui","quoi","comment","pourquoi",
        "tu","vous","je","il","elle","on"
    }

    user_words = [w for w in re.findall(r"\w+", text) if w not in stop_words]

    for q in quiz_data:
        question_text = q["question"].lower()
        question_words = [w for w in re.findall(r"\w+", question_text) if w not in stop_words]
        common = set(user_words) & set(question_words)

        if len(common) >= 2:
            correct = None
            wrong = []

            for opt in q["options"]:
                if opt["vrai"]:
                    correct = opt["text"]
                else:
                    wrong.append(opt["text"])

            lie = random.randint(1,4) == 1

            if lie:
                answer = random.choice(wrong)
                print("[QUIZ] Mensonge choisi en interne :", answer)
                is_correct = False
            else:
                answer = correct
                print("[QUIZ] Réponse correcte choisie en interne :", answer)
                is_correct = True

            return answer, is_correct

    return None, None

